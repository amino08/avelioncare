# Production (set in Vercel → Settings → Environment Variables)
NEXT_PUBLIC_SITE_URL=https://avelioncare.com

# Waitlist storage (Supabase → Project Settings → API)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin dashboard (/admin/waitlist)
ADMIN_WAITLIST_PASSWORD=your-strong-admin-password

# Local dev — copy to .env.local
# NEXT_PUBLIC_SITE_URL=http://localhost:3007
